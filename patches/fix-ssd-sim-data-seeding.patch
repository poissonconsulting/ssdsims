+# Regression: bug #3 — with_lecuyer_cmrg_seed() forwarded its `seed` argument
+# to withr::with_seed(), which routes through set.seed() and silently uses
+# only the first element of a vector seed. L'Ecuyer-CMRG stream seeds are
+# length-7 integer vectors whose first element is always 407L (the RNGkind
+# marker), so every distinct stream collapsed to the same RNG state. Distinct
+# vector seeds must now produce distinct RNG output.
+test_that("with_lecuyer_cmrg_seed honours full vector seed", {
+  s1 <- get_lecuyer_cmrg_seeds_stream(
+    seed = 1,
+    nsim = 1,
+    stream = 1,
+    start_sim = 1
+  )[[1]]
+  s2 <- get_lecuyer_cmrg_seeds_stream(
+    seed = 1,
+    nsim = 1,
+    stream = 2,
+    start_sim = 1
+  )[[1]]
+  expect_identical(s1[1], s2[1])
+  a <- with_lecuyer_cmrg_seed(s1, stats::runif(5))
+  b <- with_lecuyer_cmrg_seed(s2, stats::runif(5))
+  expect_false(identical(a, b))
+})
+
+test_that("with_lecuyer_cmrg_seed scalar seed still works", {
+  a <- with_lecuyer_cmrg_seed(42, stats::runif(3))
+  b <- with_lecuyer_cmrg_seed(42, stats::runif(3))
+  expect_identical(a, b)
+})
+
