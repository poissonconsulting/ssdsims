 })
+
+# Regression: bug #1 — ssd_sim_data.function ignored precomputed L'Ecuyer-CMRG
+# stream seeds, mapping over raw sim integers instead. After the fix, the
+# function-kind generator uses proper L'Ecuyer-CMRG stream seeds, so two
+# different streams must produce distinct values for the same (sim, seed).
+test_that("ssd_sim_data.function uses L'Ecuyer-CMRG streams across streams", {
+  a <- ssd_sim_data(
+    ssdtools::ssd_rlnorm,
+    nrow = 5,
+    nsim = 1,
+    seed = 42,
+    stream = 1
+  )
+  b <- ssd_sim_data(
+    ssdtools::ssd_rlnorm,
+    nrow = 5,
+    nsim = 1,
+    seed = 42,
+    stream = 2
+  )
+  expect_false(identical(a$data[[1]]$Conc, b$data[[1]]$Conc))
+})
+
+# Regression: bug #3 — distinct sims must produce distinct data. Previously
+# the vector seeds collapsed via set.seed()'s first-element-only behaviour so
+# every sim used the same RNG state and produced identical samples.
+test_that("ssd_sim_data.data.frame differs across sims", {
+  data <- ssd_sim_data(ssddata::ccme_boron, nrow = 5, nsim = 3, seed = 42)
+  expect_false(identical(data$data[[1]], data$data[[2]]))
+  expect_false(identical(data$data[[2]], data$data[[3]]))
+})
+
+test_that("ssd_sim_data.function differs across sims", {
+  data <- ssd_sim_data(ssdtools::ssd_rlnorm, nrow = 5, nsim = 3, seed = 42)
+  expect_false(identical(data$data[[1]], data$data[[2]]))
+  expect_false(identical(data$data[[2]], data$data[[3]]))
+})
+
+# Regression: bug #2 — vectorized branches of ssd_sim_data.* silently dropped
+# the master `seed` argument on recursion. After the fix, passing `seed = N`
+# yields the same per-(sim, stream, ...) data whether or not other args are
+# vectorized, and identical between two calls with the same seed.
+test_that("ssd_sim_data.data.frame seed propagates through vectorization", {
+  a <- ssd_sim_data(
+    ssddata::ccme_boron,
+    nrow = c(5, 10),
+    nsim = 2,
+    seed = 7
+  )
+  b <- ssd_sim_data(
+    ssddata::ccme_boron,
+    nrow = c(5, 10),
+    nsim = 2,
+    seed = 7
+  )
+  expect_equal(a$data, b$data)
+})
+
+test_that("ssd_sim_data.function seed propagates through vectorization", {
