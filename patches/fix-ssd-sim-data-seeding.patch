 with_lecuyer_cmrg_seed <- function(seed, code) {
   force(seed)
-  withr::with_seed(
-    seed,
-    code,
-    .rng_kind = "L'Ecuyer-CMRG",
-    .rng_normal_kind = "Inversion",
-    .rng_sample_kind = "Rejection"
-  )
+  # withr::with_seed() funnels its `seed` argument through set.seed(), which
+  # only honours the first element of a vector. L'Ecuyer-CMRG stream seeds
+  # produced by parallel::nextRNGStream() are length-7 integer vectors and
+  # must be assigned directly to .Random.seed to take effect — otherwise
+  # every stream collapses to set.seed(407L) and all sims produce identical
+  # output.
+  if (length(seed) > 1L) {
+    withr::with_preserve_seed({
+      RNGkind("L'Ecuyer-CMRG", "Inversion", "Rejection")
+      assign(".Random.seed", as.integer(seed), envir = globalenv())
+      force(code)
+    })
+  } else {
+    withr::with_seed(
+      seed,
+      code,
+      .rng_kind = "L'Ecuyer-CMRG",
+      .rng_normal_kind = "Inversion",
+      .rng_sample_kind = "Rejection"
+    )
+  }
 }
 
